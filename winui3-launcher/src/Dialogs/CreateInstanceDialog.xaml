<ContentDialog
    x:Class="PrismLauncherWinUI3.CreateInstanceDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    Title="创建新实例"
    PrimaryButtonText="创建"
    SecondaryButtonText="取消"
    DefaultButton="Primary">

    <Grid MinWidth="400" MinHeight="300">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 实例信息 -->
        <StackPanel Grid.Row="0" Spacing="16">
            <TextBlock Text="实例信息" Style="{StaticResource PrismSubtitleTextStyle}"/>
            
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="实例名称:" 
                           Style="{StaticResource PrismBodyTextStyle}" 
                           VerticalAlignment="Center" Margin="0,0,16,0"/>
                <TextBox Grid.Row="0" Grid.Column="1" x:Name="InstanceNameTextBox" 
                         PlaceholderText="输入实例名称" Margin="0,0,0,16"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Minecraft版本:" 
                           Style="{StaticResource PrismBodyTextStyle}" 
                           VerticalAlignment="Center" Margin="0,0,16,0"/>
                <ComboBox Grid.Row="1" Grid.Column="1" x:Name="VersionComboBox" 
                          PlaceholderText="选择版本" Margin="0,0,0,16"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="分组:" 
                           Style="{StaticResource PrismBodyTextStyle}" 
                           VerticalAlignment="Center" Margin="0,0,16,0"/>
                <ComboBox Grid.Row="2" Grid.Column="1" x:Name="GroupComboBox" 
                          PlaceholderText="选择分组" Margin="0,0,0,16"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="图标:" 
                           Style="{StaticResource PrismBodyTextStyle}" 
                           VerticalAlignment="Center" Margin="0,0,16,0"/>
                <Button Grid.Row="3" Grid.Column="1" x:Name="IconButton" 
                        Content="选择图标" HorizontalAlignment="Left" Margin="0,0,0,16"/>
            </Grid>
        </StackPanel>

        <!-- 高级选项 -->
        <Expander Grid.Row="1" Header="高级选项" Margin="0,16,0,0">
            <StackPanel Spacing="12" Margin="0,16,0,0">
                <CheckBox x:Name="CreateWorldCheckBox" Content="创建新世界" 
                          Foreground="{StaticResource PrismTextPrimaryBrush}"/>
                <CheckBox x:Name="InstallForgeCheckBox" Content="安装Forge" 
                          Foreground="{StaticResource PrismTextPrimaryBrush}"/>
                <CheckBox x:Name="InstallFabricCheckBox" Content="安装Fabric" 
                          Foreground="{StaticResource PrismTextPrimaryBrush}"/>
            </StackPanel>
        </Expander>

        <!-- 状态信息 -->
        <Border Grid.Row="2" Background="{StaticResource PrismCardBrush}" 
                CornerRadius="{StaticResource PrismCornerRadiusM}" 
                Padding="16" Margin="0,16,0,0">
            <StackPanel>
                <TextBlock Text="状态" Style="{StaticResource PrismSubtitleTextStyle}" 
                           Margin="0,0,0,8"/>
                <TextBlock x:Name="StatusText" Text="准备创建实例..." 
                           Style="{StaticResource PrismBodyTextStyle}"/>
            </StackPanel>
        </Border>
    </Grid>
</ContentDialog>