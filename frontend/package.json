{
  "name": "prism-launcher-frontend",
  "version": "1.0.0",
  "description": "Modern FluentUI desktop frontend for Prism Launcher with Tauri",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
